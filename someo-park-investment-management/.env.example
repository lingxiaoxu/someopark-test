# API Server
API_PORT=3001
BACKEND_ROOT=..

# MongoDB
MONGO_URI=mongodb://user:pass@host:port/db

# ===== AI Chat Platform Keys =====

# E2B API Key - Required for code execution sandbox (https://e2b.dev)
E2B_API_KEY=

# Anthropic API Key (Claude models)
ANTHROPIC_API_KEY=

# OpenAI API Key (GPT models) - optional, users can input their own
OPENAI_API_KEY=

# Google AI API Key (Gemini models)
GOOGLE_AI_API_KEY=

# HuggingFace Token (optional)
HF_TOKEN=

# Hyperbolic API Key (optional)
HYPERBOLIC_API_KEY=

# Hide local Ollama models in model picker
NEXT_PUBLIC_HIDE_LOCAL_MODELS=true

# Enable Morph Apply mode for diff-based code editing
NEXT_PUBLIC_USE_MORPH_APPLY=true

# Morph API Key (https://morphllm.com)
MORPH_API_KEY=

# Supabase (auth + chat history) — VITE_ prefix for frontend access
VITE_ENABLE_SUPABASE=true
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
